
@model Albergue_aspnet_DAS.Models.VistaModelo.ALbergueVM

@{
    ViewData["Title"] = "Albergue_Detalle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (Model.oAlbergue.IdAlb == 0)
{
    <h1>Crear Albergue</h1>

}
else
{
    <h1>Editar Albergue</h1>

}

<div class="row">
    <div class="col-sm-4">

        <form asp-action="Albergue_Detalle" asp-controller="Home" method="post" id="Index" >
             <input  type="hidden" asp-for="oAlbergue.IdAlb"/>

            <div class="mb-2">
                <label class="form-label" asp-for="oAlbergue.NombreAlb"> Nommbre Completo</label>
                <input class="form-control form-control-sm" asp-for="oAlbergue.NombreAlb" type="text" />
            </div>

            <div class="mb-2">
                <label class="form-label" asp-for="oAlbergue.DireccionAlb"> Dirección Completa</label>
                <input class="form-control form-control-sm" asp-for="oAlbergue.DireccionAlb" type="text" />

            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="oAlbergue.IdDist"> Distrito</label>
                <select class="form-select form-select-sm" asp-for="oAlbergue.IdDist" asp-items="@Model.oListaDistrito">
                    <option selected disabled>--Seleccionar--</option>
                </select>

            </div>


            <div class="mb-3">
                <label class="form-label" asp-for="oAlbergue.IdProv"> Provincia</label>
                <select class="form-select form-select-sm" asp-for="oAlbergue.IdProv" asp-items="@Model.oListaProvincia">
                    <option selected disabled>--Seleccionar--</option>
                </select>

            </div>

            <div class="mb-2">
                <label class="form-label" asp-for="oAlbergue.CapacidadAlb"> Capacidad de mascotas</label>
                <input class="form-control form-control-sm" asp-for="oAlbergue.CapacidadAlb" type="text" />

            </div>

            <div class="mb-2">
                <label class="form-label" asp-for="oAlbergue.CorreoAlb"> Correo</label>
                <input class="form-control form-control-sm" asp-for="oAlbergue.CorreoAlb" type="text" />

            </div>

            <div class="mb-2">
                <label class="form-check-label" for="chkEstado">Activo</label>
                <input class="form-check-input" asp-for="oAlbergue.Estado" type="checkbox" id="chkEstado" />
            </div>

            <div class="mb-2">

                @if (Model.oAlbergue.IdAlb == 0)
                {
                    <button class="btn btn-primary btn-sm w-25" type="submit" onclik="GuardarCambios(event)">Crear</button>
                   
                }
                else
                {
                    <button class="btn btn-primary btn-sm w-25" type="submit" onclick="ActualizarCambios(event)">Actualizar</button>

                }

                <a class="btn btn-success btn-sm" asp-action="Index" asp-controller ="Home">Volver</a>

            </div>
        </form>

    </div>
</div>

@section Scripts{

    <script>

        function GuardarCambios(event)
        {
            event.preventDefault(); //Evita el envío del formulario

            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: "btn btn-success",
                    cancelButton: "btn btn-danger"
                },
                buttonsStyling: false
            });
            swalWithBootstrapButtons.fire({
                title: "¿Estas seguro?",
                text: "dale",
                icon: "info",
                showCancelButton: true,
                confirmButtonText: "Guardar",
                cancelButtonText: "Cancelar",
                reverseButtons: true
            }).then((resultado) => {
                if (resultado.isConfirmed) {
                    swalWithBootstrapButtons.fire({
                        title: "Guardado!",
                        text: "Los datos han sido guardados exitosamente.",
                        icon: "success"
                    }).then(() => {
                        // Envía el formulario manualmente
                        document.getElementById("Index").submit();
                    });
                } else if (
                    /* Read more about handling dismissals below */
                    resultado.dismiss === Swal.DismissReason.cancel
                ) {
                    swalWithBootstrapButtons.fire({
                        title: "Cancelado",
                        text: "Los datos no se han guardado",
                        icon: "error"
                    });
                }
            });
        }

        function ActualizarCambios(event) 
        {
            event.preventDefault(); //Evita el envío del formulario

            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: "btn btn-success",
                    cancelButton: "btn btn-danger"
                },
                buttonsStyling: false
            });
            swalWithBootstrapButtons.fire({
                title: "¿Estas seguro?",
                text: "dale",
                icon: "info",
                showCancelButton: true,
                confirmButtonText: "Actualizar",
                cancelButtonText: "Cancelar",
                reverseButtons: true
            }).then((resultado) => {
                if (resultado.isConfirmed) {
                    swalWithBootstrapButtons.fire({
                        title: "Actualizado!",
                        text: "Los datos han sido actualizados exitosamente.",
                        icon: "success"
                    }).then(() => {
                        // Envía el formulario manualmente
                        document.getElementById("Index").submit();
                    });
                } else if (
                    /* Read more about handling dismissals below */
                    resultado.dismiss === Swal.DismissReason.cancel
                ) {
                    swalWithBootstrapButtons.fire({
                        title: "Canceladoo",
                        text: "Los datos no se han actualizado",
                        icon: "error"
                    });
                }
            });
        }

    </script>
}


