
@{
    ViewData["Title"] = "Imagen";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Imagen</h1>

@{
    ViewData["Title"] = "Subir Imagen de Mascota";
}
<!-- Define el título de la página que aparecerá en el encabezado del navegador -->

<h2>Cargar Imagen de Mascota</h2>
<!-- Encabezado principal de la página -->

