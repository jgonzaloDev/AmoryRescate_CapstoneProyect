@model Albergue_aspnet_DAS.Models.VistaModelo.MascotaVM
@{
    ViewData["Title"] = "Albergue_Detalle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



@if (Model.oMascota.IdMas == 0)
{
    <h1>Crear MAscota</h1>

}
else
{
    <h1>Editar MAscota</h1>

}

<div class="row">
    <div class="col-sm-4">

        <form asp-action="Mascota_Detalle" asp-controller="Mascota" enctype="multipart/form-data" method="post" id="IndexMas">
            <input type="hidden" asp-for="oMascota.IdMas" />

            <div class="mb-2">
                <label class="form-label" asp-for="oMascota.NombreMas"> Nommbre Completo</label>
                <input class="form-control form-control-sm" asp-for="oMascota.NombreMas" type="text" />
            </div>


            <div class="mb-3">
                <label class="form-label" asp-for="oMascota.IdTipMas"> Tipos</label>
                <select class="form-select form-select-sm" asp-for="oMascota.IdTipMas" asp-items="@Model.oListaTiposMascotas">
                    <option selected disabled>--Seleccionar--</option>
                </select>

            </div>


            <div class="mb-3">
                <label class="form-label" asp-for="oMascota.IdRazMas">Razas</label>
                <select class="form-select form-select-sm" asp-for="oMascota.IdRazMas" asp-items="@Model.oListaRazaMascotas">
                    <option selected disabled>--Seleccionar--</option>
                </select>

            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="oMascota.SexoMas">Sexo</label>
                <div>
                    <input type="radio" asp-for="oMascota.SexoMas" value="M" id="SexoMacho" />
                    <label for="SexoMacho">Macho</label>
                </div>
                <div>
                    <input type="radio" asp-for="oMascota.SexoMas" value="H" id="SexoHembra" />
                    <label for="SexoHembra">Hembra</label>
                </div>
            </div>

            <div class="mb-2">
                <label class="form-label" asp-for="oMascota.TamanioMas">Tamaño</label>
                <input class="form-control form-control-sm" asp-for="oMascota.TamanioMas" type=" text" />

            </div>

            <div class="mb-2">
                <label class="form-label" asp-for="oMascota.ColorMas">Color</label>
                <input class="form-control form-control-sm" asp-for="oMascota.ColorMas" type=" text" />

            </div>

            <div class="mb-2">
                <label class="form-label" asp-for="oMascota.FechaNacMas"> Fecha de nacimiento</label>
                <input class="form-control form-control-sm" asp-for="oMascota.FechaNacMas" type="date" />

            </div>


            <div class="mb-2">
                <label class="form-label" asp-for="oMascota.ImagenMas">Foto</label>
                <input class="form-control form-control-sm" asp-for="oMascota.ImagenMas" type="file" name="ImagenMas" accept="image/*" onchange="previewImage(event)" required />
                <span class="text-info">Sube una imagen de la mascota</span>
            </div>

            <div class="mb-3">
                <label class="form-label">Vista Previa:</label>
                <!-- Etiqueta descriptiva para la sección de vista previa -->
                <div id="vistaPrevia" style="width: 100%; max-width: 500px; height: 300px; border: 2px dashed #ccc; display: flex; align-items: center; justify-content: center; overflow: hidden; background-color: #f8f9fa;">
                    <!-- Contenedor donde aparecerá la imagen cargada -->
                    <span style="color: #aaa;">No se ha cargado ninguna imagen</span>
                    <!-- Texto que aparece por defecto si no se ha cargado ninguna imagen -->
                </div>
            </div>
            @if (Model.oMascota.ImagenMas != null && Model.oMascota.ImagenMas.Length > 0)
            {
                <div class="mt-3">
                    <label>Imagen Actual:</label>
                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.oMascota.ImagenMas)"
                         alt="Imagen de la mascota" class="img-thumbnail" style="max-width: 200px;" />
                </div>
            }

            <div class="mb-2">
                <label class="form-check-label" for="chkEstado">Activo</label>
                <input class="form-check-input" asp-for="oMascota.Estado" type="checkbox" id="chkEstado" />
            </div>


            <div class="mb-3">
                <label class="form-label" asp-for="oMascota.IdAlb">Albergues</label>
                <select class="form-select form-select-sm" asp-for="oMascota.IdAlb" asp-items="@Model.oListaALbergues">
                    <option selected disabled>--Seleccionar--</option>
                </select>

            </div>

            <div class="mb-2">

                @if (Model.oMascota.IdMas == 0)
                {
                    <button class="btn btn-primary btn-sm w-25" type="submit" onclik="GuardarCambios(event)">Crear</button>

                }
                else
                {
                    <button class="btn btn-primary btn-sm w-25" type="submit" onclick="ActualizarCambios(event)">Actualizar</button>

                }

                <a class="btn btn-success btn-sm" asp-action="IndexMas" asp-controller="Mascota">Volver</a>

            </div>
        </form>

    </div>
</div>

@section Scripts {

    <script>

        function GuardarCambios(event) {
            event.preventDefault(); //Evita el envío del formulario

            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: "btn btn-success",
                    cancelButton: "btn btn-danger"
                },
                buttonsStyling: false
            });
            swalWithBootstrapButtons.fire({
                title: "¿Estas seguro?",
                text: "dale",
                icon: "info",
                showCancelButton: true,
                confirmButtonText: "Guardar",
                cancelButtonText: "Cancelar",
                reverseButtons: true
            }).then((resultado) => {
                if (resultado.isConfirmed) {
                    swalWithBootstrapButtons.fire({
                        title: "Guardado!",
                        text: "Los datos han sido guardados exitosamente.",
                        icon: "success"
                    }).then(() => {
                        // Envía el formulario manualmente
                        document.getElementById("IndexMas").submit();
                    });
                } else if (
                    /* Read more about handling dismissals below */
                    resultado.dismiss === Swal.DismissReason.cancel
                ) {
                    swalWithBootstrapButtons.fire({
                        title: "Cancelado",
                        text: "Los datos no se han guardado",
                        icon: "error"
                    });
                }
            });
        }

        function ActualizarCambios(event) {
            event.preventDefault(); //Evita el envío del formulario

            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: "btn btn-success",
                    cancelButton: "btn btn-danger"
                },
                buttonsStyling: false
            });
            swalWithBootstrapButtons.fire({
                title: "¿Estas seguro?",
                text: "",
                icon: "info",
                showCancelButton: true,
                confirmButtonText: "Actualizar",
                cancelButtonText: "Cancelar",
                reverseButtons: true
            }).then((resultado) => {
                if (resultado.isConfirmed) {
                    swalWithBootstrapButtons.fire({
                        title: "Actualizado!",
                        text: "Los datos han sido actualizados exitosamente.",
                        icon: "success"
                    }).then(() => {
                        // Envía el formulario manualmente
                        document.getElementById("IndexMas").submit();
                    });
                } else if (
                    /* Read more about handling dismissals below */
                    resultado.dismiss === Swal.DismissReason.cancel
                ) {
                    swalWithBootstrapButtons.fire({
                        title: "Canceladoo",
                        text: "Los datos no se han actualizado",
                        icon: "error"
                    });
                }
            });
        }

        //Imagenes
        function previewImage(event) {
            // Función que muestra la vista previa de la imagen seleccionada
            const vistaPrevia = document.getElementById("vistaPrevia");
            // Obtiene el contenedor de la vista previa

            const archivo = event.target.files[0];
            // Obtiene el archivo seleccionado por el usuario

            if (archivo) {
                const reader = new FileReader();
                // Crea un objeto FileReader para leer el contenido del archivo

                reader.onload = function (e) {
                    // Evento que se ejecuta cuando el archivo se ha cargado correctamente
                    vistaPrevia.innerHTML = `<img src="${e.target.result}" style="width: 100%; height: 100%; object-fit: cover;" alt="Vista Previa">`;
                    // Actualiza el contenido del contenedor de vista previa con la imagen cargada
                    // 'src' contiene la URL de la imagen cargada
                    // 'style="width: 100%; height: 100%; object-fit: cover;"' asegura que la imagen ocupe todo el cuadro manteniendo su proporción
                    // 'alt="Vista Previa"' proporciona un texto alternativo en caso de error
                };

                reader.readAsDataURL(archivo);
                // Lee el archivo como una URL de datos (base64)
            } else {
                vistaPrevia.innerHTML = `<span style="color: #aaa;">No se ha cargado ninguna imagen</span>`;
                // Si no hay archivo seleccionado, muestra el texto por defecto
            }
        }
    </script>
}


