<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Amor y Rescate</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Nunito+Sans:ital,opsz,wght@0,6..12,300..1000;1,6..12,300..1000&display=swap" rel="stylesheet">

    <!-- Bootstrap + Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Albergue_aspnet_DAS.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- ============================================= -->
    <!-- NAVBAR -->
    <!-- ============================================= -->
    <header>
        <nav class="navbar navbar-expand-lg fixed-top navbar-custom">
            <div class="container">

                <!-- Logo y Marca -->
                <a class="navbar-brand d-flex align-items-center" asp-controller="Pestanias" asp-action="Inicio">
                    <div class="brand-icon">
                        <img src="/image/amoryrescate.jpg" alt="Logo Amor y Rescate" width="36" height="36">
                    </div>
                    <span class="brand-text">Amor y Rescate</span>
                </a>

                <!-- Toggler móvil -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Menú de navegación">
                    <i class="bi bi-list text-white fs-4"></i>
                </button>

                <!-- Contenido colapsable -->
                <div class="collapse navbar-collapse" id="mainNav">

                    <!-- Links principales -->
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pestanias" asp-action="Inicio">
                                <i class="bi bi-house-door me-1"></i>Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pestanias" asp-action="Perros">
                                <i class="bi bi-emoji-heart-eyes me-1"></i>Perros
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pestanias" asp-action="Gatos">
                                <i class="bi bi-emoji-smile me-1"></i>Gatos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pestanias" asp-action="Otros">
                                <i class="bi bi-stars me-1"></i>Otros
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pestanias" asp-action="Adopciones">
                                <i class="bi bi-heart me-1"></i>Adopciones
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="SinLogica" asp-action="ComoAdoptar">
                                <i class="bi bi-question-circle me-1"></i>¿Cómo adoptar?
                            </a>
                        </li>

                        <!-- Dropdown Registro -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-clipboard-plus me-1"></i>Registro
                            </a>
                            <ul class="dropdown-menu dropdown-menu-custom">
                                <li>
                                    <a class="dropdown-item" href="/Home/Index">
                                        <i class="bi bi-building me-2"></i>Albergues
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/RazaMascotasControllers/IndexRM">
                                        <i class="bi bi-tags me-2"></i>Raza Mascota
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/TipoMascota/IndexTM">
                                        <i class="bi bi-bookmark me-2"></i>Tipo Mascota
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" href="/Mascota/IndexMas">
                                        <i class="bi bi-heart-pulse me-2"></i>Mascotas
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>

                    <!-- Buscador -->
                    <form class="search-form d-flex align-items-center me-2" role="search"
                          asp-controller="Pestanias" asp-action="Buscar" method="get">
                        <div class="search-wrapper">
                            <i class="bi bi-search search-icon"></i>
                            <input class="form-control search-input" type="search"
                                   name="q" placeholder="Buscar mascota..." aria-label="Buscar">
                        </div>
                    </form>

                    <!-- Botón Iniciar Sesión / Usuario -->
                    @if (Context.Session.GetString("UsuarioNombre") != null)
                    {
                        <div class="dropdown">
                            <button class="btn btn-user-logged dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-check-fill me-1"></i>
                                @Context.Session.GetString("UsuarioNombre")
                            </button>
                            <ul class="dropdown-menu dropdown-menu-custom dropdown-menu-end">
                                <li>
                                    <span class="dropdown-item-text" style="font-size: 0.8rem; color: var(--gris-500);">
                                        <i class="bi bi-envelope me-1"></i>
                                        @Context.Session.GetString("UsuarioCorreo")
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2 text-coral"></i>Cerrar sesión
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-login" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-person-circle me-1"></i>Iniciar Sesión
                        </a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <!-- ============================================= -->
    <!-- CONTENIDO PRINCIPAL -->
    <!-- ============================================= -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- ============================================= -->
    <!-- FOOTER -->
    <!-- ============================================= -->
    <footer class="footer-custom">
        <div class="container">
            <div class="row g-4">

                <!-- Columna 1: Marca -->
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand">
                        <img src="/image/amoryrescate.jpg" alt="Logo" width="40" height="40">
                        <span>Amor y Rescate</span>
                    </div>
                    <p class="footer-desc">
                        El sitio ideal para encontrar un amigo de compañía y
                        disfrutar bellos momentos con él. Cada adopción salva una vida.
                    </p>
                    <div class="footer-social">
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>

                <!-- Columna 2: Links rápidos -->
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-title">Explorar</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Pestanias" asp-action="Perros">Perros</a></li>
                        <li><a asp-controller="Pestanias" asp-action="Gatos">Gatos</a></li>
                        <li><a asp-controller="Pestanias" asp-action="Otros">Otros animales</a></li>
                        <li><a asp-controller="Pestanias" asp-action="Adopciones">Adopciones</a></li>
                    </ul>
                </div>

                <!-- Columna 3: Información -->
                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-title">Información</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="SinLogica" asp-action="ComoAdoptar">¿Cómo adoptar?</a></li>
                        <li><a href="#">Preguntas frecuentes</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Política de privacidad</a></li>
                        <li><a href="#">Términos de uso</a></li>
                    </ul>
                </div>

                <!-- Columna 4: Contacto -->
                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-title">Contacto</h6>
                    <ul class="footer-contact">
                        <li>
                            <i class="bi bi-geo-alt"></i>
                            <span>Lima, Perú</span>
                        </li>
                        <li>
                            <i class="bi bi-envelope"></i>
                            <span>contacto@amoryrescate.com</span>
                        </li>
                        <li>
                            <i class="bi bi-telephone"></i>
                            <span>+51 999 888 777</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Línea divisora + Copyright -->
            <div class="footer-bottom">
                <p>&copy; 2024 Amor y Rescate — Desarrollado por el Grupo 1</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Efecto navbar al scroll -->
    <script>
        window.addEventListener('scroll', function () {
            const navbar = document.querySelector('.navbar-custom');
            if (window.scrollY > 50) {
                navbar.classList.add('navbar-scrolled');
            } else {
                navbar.classList.remove('navbar-scrolled');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
