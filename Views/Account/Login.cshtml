@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var error = ViewData["Error"]?.ToString();
}

<section class="section" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">

                <!-- Card de Login -->
                <div class="auth-card">
                    <!-- Header -->
                    <div class="auth-header">
                        <div class="auth-icon">
                            <i class="bi bi-person-circle"></i>
                        </div>
                        <h3 class="auth-title">Iniciar sesión</h3>
                        <p class="auth-subtitle">Ingresa a tu cuenta de Amor y Rescate</p>
                    </div>

                    <!-- Error -->
                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="auth-alert auth-alert-error">
                            <i class="bi bi-exclamation-triangle me-2"></i> @error
                        </div>
                    }

                    <!-- Formulario -->
                    <form method="post" asp-controller="Account" asp-action="Login">
                        <div class="auth-field">
                            <label class="auth-label">
                                <i class="bi bi-envelope me-1"></i> Correo electrónico
                            </label>
                            <input type="email" name="correo" class="form-control-custom"
                                   placeholder="tu@correo.com" required autofocus>
                        </div>

                        <div class="auth-field">
                            <label class="auth-label">
                                <i class="bi bi-lock me-1"></i> Contraseña
                            </label>
                            <div class="auth-password-wrapper">
                                <input type="password" name="contrasena" id="passwordInput"
                                       class="form-control-custom" placeholder="••••••••" required>
                                <button type="button" class="auth-toggle-password"
                                        onclick="togglePassword()">
                                    <i class="bi bi-eye" id="eyeIcon"></i>
                                </button>
                            </div>
                        </div>

                        <button type="submit" class="btn-coral w-100 py-2 mt-3"
                                style="font-size: 1rem;">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Iniciar sesión
                        </button>
                    </form>

                    <!-- Footer -->
                    <div class="auth-footer">
                        <p>
                            ¿No tienes cuenta?
                            <a asp-controller="Account" asp-action="Registro"
                               style="color: var(--coral); font-weight: 700;">
                                Regístrate aquí
                            </a>
                        </p>
                    </div>

                    <!-- Demo info -->
                    <div class="auth-demo-info">
                        <i class="bi bi-info-circle me-1"></i>
                        <span>Demo: admin@@amoryrescate.com / admin123</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function togglePassword() {
            var input = document.getElementById('passwordInput');
            var icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}

